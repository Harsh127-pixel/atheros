// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String       @id @default(uuid())
  email        String       @unique
  name         String?
  role         Role         @default(USER)
  isBanned     Boolean      @default(false)
  upgradeLevel Int          @default(0) // 0: Free, 1: Pro, 2: Enterprise
  deployments  Deployment[]
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}

model SystemSettings {
  id                     String   @id @default("global-settings")
  maintenanceMode        Boolean  @default(false)
  freeTierEnabled        Boolean  @default(true)
  subscriptionModelOn    Boolean  @default(true)
  updatedAt              DateTime @updatedAt
}

enum Role {
  USER
  ADMIN
}

model Deployment {
  id             String   @id @default(uuid())
  repoUrl        String
  status         String   @default("PENDING") // PENDING, IN_PROGRESS, SUCCESS, FAILED
  cloudProvider  String?  // AWS, VERCEL, RENDER, AZURE
  url            String?  // The live deployment URL
  commitHash     String?
  analysisResult String?  @db.Text
  securityScore  Int?     @default(0)
  buildLogs      String?  @db.Text
  reasoning      String?  @db.Text
  userId         String?
  user           User?    @relation(fields: [userId], references: [id])
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}
