# Database Connection (Neon.tech PostgreSQL)
# Replace with your actual database URL
DATABASE_URL="postgresql://user:password@hostname:5432/aetheros?sslmode=require"

# Server Port
PORT=4000

# Vercel App URL (Allowed CORS)
VERCEL_URL="http://localhost:3000"

# API Security (Render API Key)
# Make sure to set this in Render environment variables
RENDER_API_KEY="aetheros_secret_key_12345"

# Node Environment
NODE_ENV="development"
